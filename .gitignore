# Python bytecode / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/

# Distribution / packaging
# Anchored to repo root: ignore the PyInstaller build/ output, NOT the
# pipeline/build/ source package (a bare `build/` matched both and silently
# kept pipeline/build/db_builder.py out of the repo, reddening CI).
/build/
dist/
*.egg-info/
*.spec.bak

# PyInstaller
*.manifest
*.spec.tmp

# IDE
.idea/
.vscode/
.cursor/
.claude/
*.swp
*.swo
*~

# OS
Thumbs.db
Desktop.ini
.DS_Store

# pytest
.pytest_cache/

# Logs
*.log

# BBB Fan Kit source assets (large binary files)
/Monsters/

# Build staging
packaging/
publish_output/

# Pipeline caches (raw HTML fetched from external sources)
pipeline/raw/cache/
pipeline/raw/.cache/

# Audit script outputs (generated; not source-of-truth)
pipeline/curation/element_audit_results.json
pipeline/curation/element_candidates.json
pipeline/curation/element_review_queue.json

# Theme preview screenshots (root-level only, not app/ui/)
/ui/

# Screenshot harness output (scripts/screenshot_panels.py)
screenshots/
